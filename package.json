{
  "name": "partywall",
  "version": "1.0.0",
  "description": "Photo booth SaaS para eventos — backend Node.js + MySQL",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"cd client && npm run dev\"",
    "build": "cd client && npm install && npm run build",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "seed": "sequelize-cli db:seed:all"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "qrcode": "^1.5.3",
    "sequelize": "^6.37.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.2"
  }
}
